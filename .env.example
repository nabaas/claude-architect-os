# OMNISTACK — All Required Keys
# Copy: cp .env.example ~/OMNISTACK/.env && nano ~/OMNISTACK/.env
# Then: ln -sf ~/OMNISTACK/.env ~/CMNDCENTER/.env
# ════════════════════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── NOTIFICATIONS ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── RESEARCH ──────────────────────────────────────────────────
FIRECRAWL_API_KEY=
PERPLEXITY_API_KEY=
GITHUB_TOKEN=

# ── DOCKER SERVICES ───────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=omnistack
POSTGRES_DB=n8n
N8N_DB_NAME=n8n
N8N_ENCRYPTION_KEY=
REDIS_URL=redis://localhost:6379

# ── N8N WEBHOOKS (auto-populated by install.sh) ───────────────
N8N_FUSION_TRIGGER_URL=
N8N_PROMPT_SUBMIT_URL=

# ── MEMORY ────────────────────────────────────────────────────
CHROMADB_URL=http://localhost:8000
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_KEY=
MEMORY_STORE_PATH=~/.amsa/memory
PATTERNS_JSON_PATH=~/.amsa/memory/patterns.json

# ── TIMEZONE ──────────────────────────────────────────────────
GENERIC_TIMEZONE=America/New_York
TZ=America/New_York
